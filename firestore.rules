rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles — only the owner can read/write
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Global weekly rankings — any authenticated user can read;
    // each user can only write their own entry
    match /rankings/{weekId}/{subcollection}/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow listing (queries) on ranking subcollections
    match /rankings/{weekId}/{subcollection} {
      allow read: if request.auth != null;
    }

    // Legends rankings — public readable (no auth required);
    // only the owner can write their own entry (via app or SyncEngine)
    match /legendsRankings/{tier}/entries/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow listing the entire entries collection
    match /legendsRankings/{tier}/entries {
      allow read: if true;
    }

    // Invite system — any authenticated user can read an inviter's doc;
    // only the owner can write their own invite doc
    match /invites/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Purchase records — idempotency check and delivery history; owner only
    match /purchases/{userId}/items/{itemId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Share codes for gifting — creator writes, authenticated user redeems
    match /shareCodes/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.status == 'pending'
        && request.resource.data.status == 'redeemed'
        && request.resource.data.redeemedBy == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'redeemedBy', 'redeemedAt']);
    }
  }
}
